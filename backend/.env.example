# Exemple de variables d'environnement pour le backend
# Copiez ce fichier en `.env` à la racine du dossier backend et adaptez les valeurs.
# WARNING: Ne commitez pas de vraies credentials.

# URL de connexion Postgres (Neon). Si présent, le serveur contient déjà des produits.
# Exemple: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Secret JWT utilisé pour signer les tokens. Obligatoire pour que /api/login renvoie un token.
# Générer par exemple: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
